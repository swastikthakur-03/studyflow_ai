# ─────────────────────────────────────────────────────────────
#  StudyFlow AI — Environment Variables
#  Copy this file to .env and fill in real values
#  NEVER commit .env to git
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=studyflow
POSTGRES_PASSWORD=studyflow_secret
POSTGRES_DB=studyflow_db
# Full URL used by the backend (auto-built in docker-compose)
DATABASE_URL=postgresql://studyflow:studyflow_secret@localhost:5432/studyflow_db

# ── ChromaDB ──────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_AUTH_TOKEN=studyflow_chroma_token

# ── JWT Authentication ────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_in_production_min_32_chars_long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Groq AI ──────────────────────────────────────────
# Get from: groq
GROQ_API_KEY=your_groq_api_key_here

# ── File Storage ──────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ── App Settings ─────────────────────────────────────────────
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=http://localhost:3000

# ── Frontend (Next.js) ───────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
